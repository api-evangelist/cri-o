  "info": {
    "_postman_id": "eb690007-0d61-4531-ae68-c01a08f696c9",
    "name": "CRI-O Status API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The CRI-O Status API is an HTTP server exposed by the cri-o daemon over a Unix domain socket (default /var/run/crio/crio.sock for the gRPC CRI and /var/run/crio/crio.info for status). It provides runtime introspection endpoints for retrieving daemon configuration, version, container information, and golang debug data. As noted upstream, this API is not considered stable for production use and is intended for debugging, operations, and tooling integrations.\n\nContact Support:\n Name: CRI-O Project",
      "type": "text/plain"
    }
  }
